# Copy to ./.env on the VPS and fill in. Read by docker-compose.yml.
# (This file is an EXAMPLE — never commit the real ./.env or server/.treasury.json.)

# --- domains (DNS A records must point to the VPS IP; Caddy gets TLS automatically) ---
DOMAIN=playhashrock.com
API_DOMAIN=api.playhashrock.com

# --- database ---
POSTGRES_PASSWORD=change-me-to-a-long-random-string
# If the password contains URL-special chars (@ : / ?), ALSO set DATABASE_URL with them
# percent-encoded (@ → %40), else the connection string mis-parses:
# DATABASE_URL=postgres://hashrock:enc%40ded@db:5432/hashrock

# --- Solana / $HASHROCK ---
# MAINNET: SOLANA_RPC=<paid Helius/Triton/QuickNode>, SOLANA_CLUSTER=mainnet-beta,
#          HASHROCK_MINT=B4z8tBZ7MmdQrGMuMx4wfKGSq1YLPwcfBixzUBLe9ory, TOKEN_DECIMALS=6
SOLANA_RPC=https://api.devnet.solana.com
SOLANA_CLUSTER=devnet
TOKEN_DECIMALS=0
HASHROCK_MINT=4bjYJZ5QUcgFqfmNVzo1e37NMgM56C3JrUKhbbmU3JqS
TREASURY_ADDRESS=6yuCSoBc3KazZKTyCAWwU8F1FVCbBHgumUCUnWQLNosQ
# server/.treasury.json (the treasury keypair) is mounted at runtime — upload it separately,
# chmod 600, and KEEP IT OFF GIT. On mainnet the treasury should be a multisig (see MAINNET.md).

# --- economy (optional overrides; defaults live in docker-compose.yml) ---
# POOL_SEED=20000   # MAINNET: MUST be ≤ $HASHROCK funded into the treasury (invariant #3)
# DAILY_EMISSION=0.10
# CREATOR_FEE=0.05
# SPAWN_INTERVAL_SEC=60
