# Postgres (local user cluster on 5433 — start via scripts/pg.sh)
DATABASE_URL=postgres://postgres@127.0.0.1:5433/hashrock

# Server
PORT=2567

# Economy (mirror of CLAUDE.md "Economy parameters" — server is authoritative)
POOL_SEED=100000000
DAILY_EMISSION=0.10
ORE_PER_DAY=1440
REWARD_FLOOR=1
CREATOR_FEE=0.05
ORE_HP=100
ORE_CAP=150
BASE_MINE_TIME_SEC=30
SPAWN_INTERVAL_SEC=60

# Solana (treasury = EOA for MVP; see CLAUDE.md invariant #5 caveat)
SOLANA_RPC=https://api.devnet.solana.com
# HASHROCK_MINT=<spl token mint address>
# TREASURY_SECRET=<base58 secret key of treasury EOA>  (KEEP OFF GIT)
