# MAINNET env template. Copy to the production .env (or set in docker-compose) ONLY after
# completing MAINNET.md (paid RPC, mint + burn authority, treasury → multisig + hot float).
# NEVER commit the real values or the treasury secret.

DATABASE_URL=postgres://hashrock:CHANGE_ME@db:5432/hashrock
PORT=2567

# economy (review MVP.md "Economy v2" before launch — these are policy, not knobs)
# ⚠️ POOL_SEED MUST be ≤ the $HASHROCK actually funded into the treasury (invariant #3:
# total coins === treasury × rate, 1:1). Initial treasury = 20,000 $HASHROCK, so the seed
# is 20,000 (the whole reserve becomes the play-to-earn budget). Seeding more = insolvent.
POOL_SEED=20000
DAILY_EMISSION=0.10
ORE_PER_DAY=1440
REWARD_FLOOR=1
CREATOR_FEE=0.05
ORE_HP=100
ORE_CAP=150
BASE_MINE_TIME_SEC=30
SPAWN_INTERVAL_SEC=60

# --- MAINNET chain ---
SOLANA_CLUSTER=mainnet-beta
# Use a PAID mainnet RPC (Helius/Triton/QuickNode). Public mainnet RPC will drop txs.
SOLANA_RPC=https://your-mainnet-rpc-provider/?api-key=CHANGE_ME

# $HASHROCK is ALREADY minted on mainnet (launched on Orynth) — do NOT run setup-chain.mjs.
# Mint: fixed ~500K supply, mint authority burned, decimals 6.
HASHROCK_MINT=B4z8tBZ7MmdQrGMuMx4wfKGSq1YLPwcfBixzUBLe9ory
# decimals MUST match the on-chain mint. initChain() hard-fails on mismatch. (devnet legacy = 0)
TOKEN_DECIMALS=6

# Fresh mainnet treasury (secret in server/.treasury.mainnet.json, chmod 600, gitignored —
# BACK UP OFFLINE). Fund it with 20,000 $HASHROCK + a little SOL for redeem fees. On mainnet
# the bulk should move to a COLD multisig with only a small hot float here (MAINNET.md §D).
TREASURY_ADDRESS=3cvBQmNZHDBo8XL6nT7YaqGYNzYSqRPVWbHvYPKdVvzL
TREASURY_SECRET_PATH=./.treasury.mainnet.json
