# Client build (Vite → static) baked into a Caddy image that serves it + auto-TLS reverse-proxies
# the API. VITE_SERVER_URL is injected at build time so the client talks to wss://<api domain>.
#   docker build -f Dockerfile.web --build-arg VITE_SERVER_URL=wss://api.example.com -t hashrock-web .

# --- stage 1: build the static client ---
FROM node:22-alpine AS build
WORKDIR /app
ARG VITE_SERVER_URL
ENV VITE_SERVER_URL=${VITE_SERVER_URL}
COPY package.json package-lock.json ./
RUN npm install --no-audit --no-fund
COPY tsconfig.json vite.config.ts index.html ./
COPY src/ ./src/
COPY shared/ ./shared/
COPY public/ ./public/
RUN npm run build           # → /app/dist

# --- stage 2: serve with Caddy (auto-HTTPS) ---
FROM caddy:2-alpine
COPY deploy/Caddyfile /etc/caddy/Caddyfile
COPY --from=build /app/dist /srv
